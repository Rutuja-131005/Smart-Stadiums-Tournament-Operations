{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_BACKEND_URL/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://YOUR_BACKEND_URL/socket.io/:path*"
    },
    {
      "source": "/((?!api|socket.io).*)",
      "destination": "/index.html"
    }
  ]
}
