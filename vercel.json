{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/:path*",
      "dest": "https://YOUR_BACKEND_URL/api/:path*"
    },
    {
      "src": "/socket.io/:path*",
      "dest": "https://YOUR_BACKEND_URL/socket.io/:path*"
    },
    {
      "src": "/assets/(.*)",
      "dest": "client/dist/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "client/dist/favicon.svg"
    },
    {
      "src": "/logo.jpg",
      "dest": "client/dist/logo.jpg"
    },
    {
      "src": "/((?!api|socket.io).*)",
      "dest": "client/dist/index.html"
    }
  ]
}
